{
  "name": "ha-unifi-drive-card",
  "version": "0.2.2",
  "description": "Mushroom-style Lovelace card for the UniFi Drive / UNAS Home Assistant integration.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memphi2/ha-unifi-drive-card.git"
  },
  "bugs": {
    "url": "https://github.com/memphi2/ha-unifi-drive-card/issues"
  },
  "homepage": "https://github.com/memphi2/ha-unifi-drive-card#readme",
  "scripts": {
    "build": "vite build",
    "anonymization-check": "node scripts/anonymization_check.mjs",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build && npm run compat && npm run license-check && npm run anonymization-check && npm run release-check && npm run security-audit",
    "compat": "node scripts/compat_check.mjs",
    "ha:live-entity-audit": "node scripts/ha_live_entity_audit.mjs",
    "ha:storage-smoke": "node scripts/ha_storage_smoke.mjs",
    "license-check": "node scripts/license_check.mjs",
    "lint": "eslint . --max-warnings=0",
    "release-check": "node scripts/release_check.mjs",
    "render-smoke": "npm run build && node scripts/render_smoke.mjs",
    "security-audit": "npm audit --omit=dev --audit-level=moderate",
    "smoke": "node scripts/ha_card_smoke.mjs",
    "smoke:install-uninstall": "npm run build && node scripts/ha_card_smoke.mjs --deploy --uninstall",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "unifi",
    "unas",
    "unifi-drive"
  ],
  "dependencies": {
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.8.0",
    "eslint": "^9.0.0",
    "jsdom": "^26.0.0",
    "puppeteer-core": "^25.0.2",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
